# =============================================================================
# Tidefly Agent Configuration
# Copy to .env and fill in the values
# =============================================================================

# ── Agent Identity ─────────────────────────────────────────────────────────
# UUID generated automatically on first install — do not change after registration
AGENT_ID=

# Human-readable name for this server (defaults to hostname)
AGENT_NAME=

AGENT_VERSION=0.1.0

# ── Plane Connection ───────────────────────────────────────────────────────
# gRPC endpoint of your Tidefly Plane
PLANE_ENDPOINT=plane.example.com:7443

# One-time registration token (generate in Tidefly UI → Servers → Add Server)
# Remove after first successful registration
PLANE_TOKEN=

# HTTP endpoint for registration (leave empty to auto-derive from PLANE_ENDPOINT)
PLANE_HTTP_ENDPOINT=

# Certificate paths (auto-populated after registration)
PLANE_CERT_FILE=/etc/tidefly-agent/client.crt
PLANE_KEY_FILE=/etc/tidefly-agent/client.key
PLANE_CA_FILE=/etc/tidefly-agent/ca.crt

# Connection settings
PLANE_DIAL_TIMEOUT=10s
PLANE_RETRY_DELAY=5s

# ── Runtime ────────────────────────────────────────────────────────────────
RUNTIME_TYPE=docker
RUNTIME_SOCKET=/var/run/docker.sock

# ── Caddy (local reverse proxy on this worker) ─────────────────────────────
CADDY_ENABLED=true
CADDY_ADMIN_URL=http://127.0.0.1:2019

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
